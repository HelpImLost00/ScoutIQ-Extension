{
  "manifest_version": 3,
  "name": "ScoutIQ",
  "version": "1.4.0",
  "description": "See the best price and all-time low for any product — powered by ScoutIQ.",
  "action": {
    "default_title": "ScoutIQ — click to show/hide pill"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
