{
  "manifest_version": 3,
  "name": "ScoutIQ",
  "version": "1.1.0",
  "description": "See the best price and all-time low for any product — powered by ScoutIQ.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ScoutIQ Price Tracker"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
